{
  "name": "n8n-nodes-htx",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for HTX (Huobi) cryptocurrency exchange providing 7 resources and 50+ operations for spot trading, futures trading, margin, account management, market data, and wallet operations.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-htx.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-htx#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-htx/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "htx",
    "huobi",
    "cryptocurrency",
    "exchange",
    "trading",
    "spot",
    "futures",
    "margin",
    "api",
    "crypto",
    "bitcoin",
    "ethereum",
    "defi",
    "automation",
    "workflow"
  ],
  "main": "dist/nodes/Htx/Htx.node.js",
  "files": [
    "dist",
    "LICENSE",
    "COMMERCIAL_LICENSE.md",
    "LICENSING_FAQ.md",
    "README.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/HtxApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Htx/Htx.node.js"
    ]
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --check \"**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "gulp-svg2png": "^2.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  }
}